# GitHub Personal Access Token. Optional but strongly recommended.
# Without a token: 10 search requests/min (anonymous). With token: 30/min.
# Generate at: https://github.com/settings/tokens (no scopes needed for public search).
GITHUB_TOKEN=

# Cap on total specs to ingest in a single crawl run. Default: 50.
MAX_SPECS=50

# Poll interval for `update` command (milliseconds). Default: 24 hours.
POLL_INTERVAL_MS=86400000

# Max retries per HTTP request inside fetcher. Default: 3.
MAX_RETRIES=3

# Consecutive failed catalog fetches before status becomes stale. Default: 3.
STALE_AFTER_RETRIES=3

# Where the catalog is persisted, relative to project root. Default: data/catalog.json.
CATALOG_PATH=data/catalog.json

# Logger threshold: debug | info | warn | error. Default: info.
LOG_LEVEL=info

# Comma-separated owner/repo list used to bootstrap a crawl when search is rate-limited.
# Example: stripe/openapi,APIs-guru/openapi-directory,github/rest-api-description
SEED_REPOS=stripe/openapi,APIs-guru/openapi-directory,github/rest-api-description,twilio/twilio-oai,microsoft/azure-rest-api-specs
