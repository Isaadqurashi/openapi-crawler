# GitHub Personal Access Token (no scopes required for public search).
# Without a token: 10 search requests/min. With token: 30/min.
GITHUB_TOKEN=

# Max specs to ingest per crawl (set 0 to disable limit — not recommended).
MAX_SPECS=80

# Path to seeds.json (raw URLs processed before GitHub search).
SEEDS_PATH=seeds.json

# Daemon/watch interval in hours.
POLL_INTERVAL_HOURS=24

# Optional override in milliseconds (defaults to POLL_INTERVAL_HOURS * 3600000).
# POLL_INTERVAL_MS=86400000

# HTTP retries inside fetcher (exponential backoff).
MAX_RETRIES=3

# Consecutive failed fetches before catalog entry status becomes stale.
STALE_AFTER_RETRIES=3

# Catalog output path (project root by default).
CATALOG_PATH=catalog.json

# Logger threshold: debug | info | warn | error
LOG_LEVEL=info

# Delay between GitHub API calls in ms (task recommends 2000).
GITHUB_REQUEST_DELAY_MS=2000

# Comma-separated owner/repo list — used after search if under MAX_SPECS.
SEED_REPOS=stripe/openapi,APIs-guru/openapi-directory,github/rest-api-description,twilio/twilio-oai
