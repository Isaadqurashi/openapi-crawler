{
  "name": "openapi-crawler",
  "version": "1.0.0",
  "description": "A CLI tool that crawls GitHub for OpenAPI/Swagger specs, parses them, tracks version changes, and persists a catalog with full history.",
  "main": "dist/index.js",
  "bin": {
    "openapi-crawler": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "crawl": "node dist/index.js crawl",
    "update": "node dist/index.js update",
    "catalog": "node dist/index.js catalog",
    "watch": "node dist/index.js watch",
    "test": "jest --coverage",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "openapi",
    "swagger",
    "crawler",
    "catalog",
    "github"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "p-limit": "^3.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
